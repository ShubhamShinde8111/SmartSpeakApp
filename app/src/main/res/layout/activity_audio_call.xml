<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/call_bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Ready"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="#FFFFFF"/>

    <ProgressBar
        android:id="@+id/progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/status"
        android:layout_marginTop="12dp"
        android:visibility="gone"/>

    <Button
        android:id="@+id/startBtn"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/progress"
        android:layout_marginTop="16dp"
        android:text="Start Conversation"
        android:background="@drawable/btn_bg"
        android:textAllCaps="false"/>

    <TextView
        android:id="@+id/waitingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/startBtn"
        android:layout_marginTop="12dp"
        android:text="Waiting for another user to join..."
        android:textColor="@color/neutral_gray"
        android:visibility="gone"/>

    <!-- In-call content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        android:id="@+id/callControls"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/speakerBtn"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/btn_round_primary"
            android:contentDescription="Speaker"
            android:src="@android:drawable/ic_lock_silent_mode_off"/>

        <View
            android:layout_width="24dp"
            android:layout_height="0dp"/>

        <ImageButton
            android:id="@+id/muteBtn"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/btn_round_primary"
            android:contentDescription="Mute"
            android:src="@android:drawable/ic_lock_silent_mode_off"/>

        <View
            android:layout_width="24dp"
            android:layout_height="0dp"/>

        <ImageButton
            android:id="@+id/endBtn"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/btn_round_danger"
            android:contentDescription="End"
            android:src="@android:drawable/ic_menu_close_clear_cancel"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/callHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/callControls"
        android:layout_marginBottom="24dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/callType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice call"
            android:textColor="#D0D2DA"/>

        <Chronometer
            android:id="@+id/callTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <ImageView
            android:id="@+id/avatar"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/person_dp"
            android:background="@drawable/rounded_corner"
            android:padding="4dp"/>

        <TextView
            android:id="@+id/connStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Connecting"
            android:textColor="#D0D2DA"/>

        
    </LinearLayout>

</RelativeLayout>


